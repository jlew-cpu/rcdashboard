# RC Dashboard — environment variables
# Copy this file to .env and fill in the values you have.
# All credentials are optional — any unconfigured source shows stub data.

# ── Greenhouse Harvest API ─────────────────────────────────────────────────
# How to get: Greenhouse > Configure > Dev Center > API Credential Management
# Create a Harvest API key with at least "Job" read permission.
# Without this: KPI "Open roles" shows stub value (23).
GREENHOUSE_API_KEY=

# ── Google Calendar API ────────────────────────────────────────────────────
# How to get:
#   1. Google Cloud Console > IAM & Admin > Service Accounts — create a service account
#   2. Enable "Google Calendar API" on the project
#   3. In Google Workspace Admin > Security > API controls > Domain-wide delegation,
#      grant the service account calendar.readonly scope
#   4. Download the service account JSON key file and set the path below
# Without this: GCal feed column shows stub items.
GCAL_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# The Google Workspace email address of the RC to impersonate via domain-wide delegation.
GCAL_USER_EMAIL=rc@yourcompany.com

# ── Slack Bot API ──────────────────────────────────────────────────────────
# How to get: https://api.slack.com/apps > Create New App > OAuth & Permissions
# Bot Token Scopes required: channels:history, im:history, im:read, users:read
# Note: search:read is a *user* scope — it is NOT required and NOT used here.
# Without this: Slack feed column shows stub items.
SLACK_BOT_TOKEN=xoxb-...

# ── ModernLoop API ─────────────────────────────────────────────────────────
# How to get: ModernLoop Settings > Integrations (if available)
# Note: ModernLoop's public API is not fully documented. When this key is set,
# the server attempts a best-effort call and logs the response shape.
# All ModernLoop sections (feed, interviewers, queue, modules) always show
# stub data until real API mapping is implemented.
MODERNLOOP_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000
